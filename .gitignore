# ======================================
# WebCheck360 — Production .gitignore
# ======================================

# ── Runtime Scan Files ──
progress.json
report.json
links.json
*.flag
*.lock

# ── Environment & Secrets ──
.env
.env.local
.env.production

# ── Logs & Cache ──
logs/
cache/
storage/logs/
storage/cache/
storage/generated_reports/
storage/exports/

# ── Uploads ──
public/uploads/

# ── Java / Maven Build ──
crawler/java/**/target/
crawler/java/**/*.class
*.jar

# ── IDE & Editor ──
.vscode/
.idea/
.project
.classpath
.settings/

# ── OS Files ──
.DS_Store
Thumbs.db
Desktop.ini

# ── Node (if any JS libs used) ──
node_modules/

# ── Backups ──
*.bak
*.backup

# ── Logs ──
*.log